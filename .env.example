# ═══════════════════════════════════════
# Creative Media — 环境变量配置
# 复制此文件为 .env.local 并填入实际值
# ⚠️ 请勿在此文件中填写真实密钥！
# ═══════════════════════════════════════

# ── Vercel Postgres ──
DATABASE_URL="postgres://..."
DIRECT_URL="postgres://..."

# ── NextAuth.js ──
NEXTAUTH_URL="https://cm.netgo.work"
NEXTAUTH_SECRET="" # 运行 openssl rand -base64 32 生成

# ── Google OAuth ──
# 在 https://console.cloud.google.com 创建 OAuth 2.0 凭据
# 回调 URL 设为: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Vercel Blob (素材存储) ──
BLOB_READ_WRITE_TOKEN=""

# ── OpenAI (Whisper ASR + GPT-4o) ──
OPENAI_API_KEY=""

# ── ElevenLabs (英文 TTS) ──
ELEVENLABS_API_KEY=""

# ── Azure Speech (中文/韩文 TTS) ──
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastasia"

# ── Stripe (订阅支付) ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ULTRA_PRICE_ID=""

# ── Inngest (异步任务) ──
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
